# MoneyForward Settings
MF_USER_ID=your_email@example.com
MF_PASSWORD=your_password

# Zaim API Settings (Optional if using MoneyForward)
ZAIM_CONSUMER_ID=your_consumer_id
ZAIM_CONSUMER_SECRET=your_consumer_secret
ZAIM_ACCESS_TOKEN=your_access_token
ZAIM_ACCESS_TOKEN_SECRET=your_access_token_secret

# AI Settings (Gemini)
GEMINI_API_KEY=your_gemini_api_key

# Slack Settings
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Obsidian Settings
OBSIDIAN_VAULT_PATH=C:/path/to/your/obsidian/vault
