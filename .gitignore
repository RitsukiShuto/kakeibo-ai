# --- Python Standard ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
build/
dist/
*.egg-info/

# --- IDE ---
.vscode/
.idea/

# --- Secrets & Credentials (CRITICAL) ---
# 全ての機密・ローカル設定ファイルを local/ に集約し、フォルダごと除外
local/.env
local/mf_session
local/*.db
local/config/*.json
!local/.env.example
!local/config/*.json.example

# --- Databases & Raw Data (PERSONAL INFO) ---
*.db
*.db-journal
input_data.json
data/csv/*
data/import/transactions/*


# --- User Profiles (PERSONAL INFO) ---
# 雛形としての .example だけ残し、実データは除外
# config/ フォルダ内の実データは local/config/ へ移動済み

# --- Reports & Temporary Outputs (PERSONAL INFO) ---
reports/
latest_review.md
debug_output.txt

# --- Logs ---
logs/*.log
*.log

