# MoneyForward Login
MF_USER_ID=your_email@example.com
MF_PASSWORD=your_password

# Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Slack (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_USER_ID=U12345678
DASHBOARD_URL=http://192.168.x.x:8501

# Obsidian
OBSIDIAN_VAULT_PATH=C:\Users\YourName\Documents\Obsidian\YourVault

# Zaim (Optional)
ZAIM_CONSUMER_ID=your_id
ZAIM_CONSUMER_SECRET=your_secret
ZAIM_ACCESS_TOKEN=your_token
ZAIM_ACCESS_TOKEN_SECRET=your_token_secret
